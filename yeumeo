function sendWish() {
  const display = document.getElementById('wishDisplay');
  display.style.opacity = '0';
  // Shooting star
  const ss = document.createElement('div');
  ss.className = 'shooting-star';
  ss.style.left = (Math.random()*80+10)+'vw';
  ss.style.top = (Math.random()*30+10)+'vh';
  document.getElementById('page5').appendChild(ss);
  setTimeout(() => ss.remove(), 1300);
  setTimeout(() => {
    display.textContent = wishes[wishIdx % wishes.length];
    wishIdx++;
    display.style.transition = 'opacity 0.8s';
    display.style.opacity = '1';
  }, 600);
}

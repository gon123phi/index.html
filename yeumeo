];
function buildMemories() {
  const board = document.getElementById('memoryBoard');
  if(board.children.length) return;
  memories.forEach((m,i) => {
    const c = document.createElement('div');
    c.className = 'memory-card';
    c.style.setProperty('--rot', m.rot);
    c.style.setProperty('--color', m.color);
    c.innerHTML = `<div class="pin"></div><div class="memory-emoji">${m.emoji}</div><div class="memory-label">${m.label}</div><div class="memory-desc">${m.desc}</div>`;
    c.style.opacity = '0';
    board.appendChild(c);
    setTimeout(() => {
      c.style.transition = 'opacity 0.5s, transform 0.5s';
      c.style.opacity = '1';
    }, 120*i + 100);
  });
}

// Stars
function buildStars() {
  const container = document.getElementById('starsContainer');
  if(container.children.length) return;
  for(let i=0;i<120;i++) {
    const s = document.createElement('div');
    s.className = 'star-dot';
    const size = Math.random()*3+0.5;
    s.style.width = size+'px'; s.style.height = size+'px';
    s.style.left = Math.random()*100+'vw';
    s.style.top = Math.random()*100+'vh';
    s.style.animationDuration = (2+Math.random()*3)+'s';
    s.style.animationDelay = Math.random()*3+'s';
    container.appendChild(s);
  }
}

